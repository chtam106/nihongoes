{
  "name": "langwish",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.6.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && tsx scripts/generate-sitemap.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:style": "stylelint \"src/**/*.css\"",
    "lint:style:fix": "stylelint \"src/**/*.css\" --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run lint:style && pnpm run format:check",
    "download:audio": "node scripts/download-kana-audio.mjs",
    "download:audio:force": "node scripts/download-kana-audio.mjs --force",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource-variable/noto-sans": "^5.2.10",
    "@fontsource-variable/noto-sans-jp": "^5.2.10",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "lighthouse": "^13.4.0",
    "prettier": "^3.8.4",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@ffmpeg-installer/darwin-arm64",
      "@ffmpeg-installer/darwin-x64",
      "@ffmpeg-installer/linux-arm",
      "@ffmpeg-installer/linux-arm64",
      "@ffmpeg-installer/linux-ia32",
      "@ffmpeg-installer/linux-x64",
      "@ffmpeg-installer/win32-ia32",
      "@ffmpeg-installer/win32-x64"
    ]
  }
}
